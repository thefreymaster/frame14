# Local development environment variables
# Copy to .env and fill in your values.
# In production (HA addon), these come from /data/options.json instead.

# Your Home Assistant instance URL
HA_URL=http://ha.unserver23.net

# Long-lived access token from HA → Profile → Long-Lived Access Tokens
HA_TOKEN=key

# Immich server URL (no trailing slash)
IMMICH_URL=http://10.23.23.100:2283/

# Immich API key from Immich → Account Settings → API Keys
IMMICH_API_KEY=token

# Express server port
PORT=4000

# Vite dev server: point to Express server for API proxying
# (set in vite.config.ts proxy, not needed here)

# (Optional) Pin a specific Immich album ID for the photo slideshow.
# When set, the album picker UI is hidden and this album is always used.
# Get the ID from the Immich album URL: /albums/<uuid>
IMMICH_ALBUM_ID=id
